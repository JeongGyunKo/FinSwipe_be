# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Finlight
FINLIGHT_API_KEY=your-finlight-api-key

# GenAI Server
GENAI_URL=https://your-genai-server.example.com
GENAI_USER=your-genai-username
GENAI_PASSWORD=your-genai-password

# Admin API (16자 이상)
ADMIN_API_KEY=your-admin-api-key-minimum-16-chars

# CORS (쉼표로 구분, 프로덕션에서는 실제 도메인으로 변경)
# CORS_ORIGINS=["https://yourapp.com","https://www.yourapp.com"]

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
# LOG_LEVEL=INFO
